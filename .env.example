# PayMonero UI Configuration
# Copy to .env and adjust values

# Database (same as PayMonero gateway — read-only access)
DATABASE_URL=postgresql://paymonero:paymonero@127.0.0.1:5432/paymonero

# PayMonero API (for future admin actions)
PAYMONERO_API_URL=http://127.0.0.1:3000
PAYMONERO_API_KEY=your-api-key-here

# UI Server
UI_HOST=127.0.0.1
UI_PORT=8080
